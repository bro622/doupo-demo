; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="斗破苍穹·斗帝之路"
config/description="《斗破苍穹》Roguelike卡牌RPG — 3角色/4场景/50敌人/163卡牌/58遗物/47事件"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.5", "GL Compatibility")
config/icon="uid://btgcr4ik6pa3c"

[autoload]

RNGManager="*res://scripts/rng_manager.gd"
PlayerManager="*res://scripts/player_manager.gd"
RunManager="*res://scripts/run_manager.gd"
SaveManager="*res://scripts/saves/save_manager.gd"
AudioManager="*res://scripts/audio_manager.gd"
SafeArea="*res://scripts/safe_area.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="斗破苍穹·斗帝之路"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_mcp/plugin.cfg")

[gui]

theme/default_font_size=18

[input]

map_toggle={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":77,"key_label":0,"unicode":109,"location":0,"echo":false,"script":null)
]
}

[rendering]

textures/vram_compression/import_etc2_astc=true
